# Application Configuration
APP_NAME=KSeF FastAPI Integration
APP_ENV=development
DEBUG=false

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./ksef.db

# KSeF API Configuration
KSEF_BASE_URL=https://api-test.ksef.mf.gov.pl/v2
KSEF_TIMEOUT_SECONDS=30
KSEF_AUTH_MODE=token
KSEF_TOKEN_VALUE=
KSEF_CLIENT_CERT_PATH=
KSEF_CLIENT_CERT_PASSWORD=
KSEF_RETRY_ATTEMPTS=3
KSEF_POLL_INTERVAL_SECONDS=2.0
KSEF_CONTEXT_IDENTIFIER_TYPE=Nip
KSEF_CONTEXT_IDENTIFIER_VALUE=
KSEF_AUTH_POLL_ATTEMPTS=10
KSEF_AUTH_POLL_INTERVAL_SECONDS=1.0

# KSeF Certificate Paths
KSEF_MF_PUBLIC_ENCRYPTION_CERT_PATH=./certificates/mf_public_encryption_cert.pem
KSEF_XADES_SIGNING_CERT_PATH=./certificates/xades_signing_cert.pem
KSEF_PRIVATE_KEY_PATH=./certificates/private_key.pem
KSEF_PRIVATE_KEY_PASSWORD=
